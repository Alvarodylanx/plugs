generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  password     String
  level        String       @default("O-Level")
  points       Int          @default(0)
  streak       Int          @default(0)
  lastStudy    DateTime?
  avatar       String?
  studyProfile Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  notes        Note[]
  sessions     Session[]
  threads      Thread[]
  replies      Reply[]
  quizResults  QuizResult[]
  readProgress ReadProgress[]
  threadLikes  ThreadLike[]
  replyLikes   ReplyLike[]
}

model Note {
  id          String       @id @default(cuid())
  title       String
  subject     String
  tags        String[]
  summary     String
  aiTip       String
  readTime    String
  level       String       @default("O-Level")
  sections    Json
  quiz        Json
  isBuiltIn   Boolean      @default(false)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readProgress ReadProgress[]
  quizResults  QuizResult[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ReadProgress {
  id         String  @id @default(cuid())
  userId     String
  noteId     String
  sectionIdx Int
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  note       Note    @relation(fields: [noteId], references: [id], onDelete: Cascade)
  @@unique([userId, noteId, sectionIdx])
}

model Session {
  id        String   @id @default(cuid())
  subject   String
  date      String
  time      String
  endTime   String
  notes     String   @default("")
  completed Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Thread {
  id        String       @id @default(cuid())
  title     String
  content   String
  subject   String
  tags      String[]
  views     Int          @default(0)
  pinned    Boolean      @default(false)
  solved    Boolean      @default(false)
  authorId  String
  author    User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies   Reply[]
  likes     ThreadLike[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Reply {
  id        String      @id @default(cuid())
  content   String
  authorId  String
  threadId  String
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  thread    Thread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  likes     ReplyLike[]
  createdAt DateTime    @default(now())
}

model ThreadLike {
  userId   String
  threadId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread   Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  @@id([userId, threadId])
}

model ReplyLike {
  userId  String
  replyId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply   Reply  @relation(fields: [replyId], references: [id], onDelete: Cascade)
  @@id([userId, replyId])
}

model QuizResult {
  id         String   @id @default(cuid())
  noteId     String
  score      Int
  total      Int
  percentage Float
  userId     String
  note       Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Badge {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String
  emoji       String
  earnedAt    DateTime  @default(now())
}

model StudyLog {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  hours     Float
  date      String
  createdAt DateTime @default(now())
}

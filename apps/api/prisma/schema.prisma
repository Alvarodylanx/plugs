generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  name             String
  email            String           @unique
  password         String
  level            String           @default("O-Level")
  points           Int              @default(0)
  streak           Int              @default(0)
  lastStudy        DateTime?
  avatar           String?
  studyProfile     Json?
  streakFreezes    Int              @default(1)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  notes            Note[]
  sessions         Session[]
  threads          Thread[]
  replies          Reply[]
  quizResults      QuizResult[]
  readProgress     ReadProgress[]
  threadLikes      ThreadLike[]
  replyLikes       ReplyLike[]
  badges           Badge[]
  teacherProfile   TeacherProfile?
  teacherFollowing TeacherFollow[]  @relation("StudentFollows")
  teacherFollowers TeacherFollow[]  @relation("TeacherFollowers")
  quikzSettings    QuikzSettings?
  quikzAnswers     QuikzAnswer[]
}

model TeacherProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects    String[]
  town        String?
  school      String?
  jobStatus   String   @default("Tutor")
  bio         String?
  verified    Boolean  @default(false)
  available   Boolean  @default(true)
  rating      Float    @default(0)
  ratingCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeacherFollow {
  studentId String
  teacherId String
  student   User     @relation("StudentFollows", fields: [studentId], references: [id], onDelete: Cascade)
  teacher   User     @relation("TeacherFollowers", fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@id([studentId, teacherId])
}

model Note {
  id           String         @id @default(cuid())
  title        String
  subject      String
  tags         String[]
  summary      String
  aiTip        String
  readTime     String
  level        String         @default("O-Level")
  sections     Json
  quiz         Json
  isBuiltIn    Boolean        @default(false)
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  readProgress ReadProgress[]
  quizResults  QuizResult[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model ReadProgress {
  id         String  @id @default(cuid())
  userId     String
  noteId     String
  sectionIdx Int
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  note       Note    @relation(fields: [noteId], references: [id], onDelete: Cascade)
  @@unique([userId, noteId, sectionIdx])
}

model Session {
  id        String   @id @default(cuid())
  subject   String
  date      String
  time      String
  endTime   String
  notes     String   @default("")
  completed Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Thread {
  id        String       @id @default(cuid())
  title     String
  content   String
  subject   String
  tags      String[]
  views     Int          @default(0)
  pinned    Boolean      @default(false)
  solved    Boolean      @default(false)
  authorId  String
  author    User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies   Reply[]
  likes     ThreadLike[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Reply {
  id           String      @id @default(cuid())
  content      String
  isBestAnswer Boolean     @default(false)
  authorId     String
  threadId     String
  author       User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  thread       Thread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  likes        ReplyLike[]
  createdAt    DateTime    @default(now())
}

model ThreadLike {
  userId   String
  threadId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread   Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  @@id([userId, threadId])
}

model ReplyLike {
  userId  String
  replyId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply   Reply  @relation(fields: [replyId], references: [id], onDelete: Cascade)
  @@id([userId, replyId])
}

model QuizResult {
  id         String   @id @default(cuid())
  noteId     String
  score      Int
  total      Int
  percentage Float
  userId     String
  note       Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Badge {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String
  emoji       String
  earnedAt    DateTime @default(now())
  @@unique([userId, name])
}

model StudyLog {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  hours     Float
  date      String
  createdAt DateTime @default(now())
}

model QuikzSettings {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled      Boolean   @default(false)
  frequencyMin Int       @default(30)
  subjects     String[]
  noteIds      String[]
  quietStart   String    @default("22:00")
  quietEnd     String    @default("07:00")
  lastSentAt   DateTime?
  pushSub      Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model QuikzAnswer {
  id          String   @id @default(cuid())
  userId      String
  noteId      String
  questionIdx Int
  correct     Int      @default(0)
  wrong       Int      @default(0)
  lastSeenAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, noteId, questionIdx])
}

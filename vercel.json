{
  "version": 2,
  "builds": [
    {
      "src": "apps/api/api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "apps/api/src/**",
          "apps/api/prisma/**",
          "node_modules/@prisma/client/**",
          "node_modules/.prisma/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/api/api/index.ts"
    }
  ]
}
